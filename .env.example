PORT=3000
APP_BASE_URL=http://localhost:3000

# Currency used for totals shown in backend responses
ORDER_CURRENCY=COP
FORMSPREE_ENDPOINT=https://formspree.io/f/xykdbqaz
FORMSPREE_TIMEOUT_MS=8000
GOOGLE_MAPS_SERVER_API_KEY=
GEOCODER_USER_AGENT=seido-cash-ordering-app/1.0
NEQUI_CHECKOUT_URL=
CARD_CHECKOUT_URL=
PAYPAL_CHECKOUT_URL=
GENERAL_CHECKOUT_URL=

# Storage and CORS
DB_FILE=./server/data/orders.sqlite
CORS_ORIGIN=*

# Optional delivery coverage (JSON array). Leave empty to disable geo coverage validation.
# Example:
# DELIVERY_ZONES_JSON=[{"id":"chapinero","name":"Chapinero","latitude":4.6486,"longitude":-74.0628,"radiusKm":7,"shippingInCents":5000},{"id":"usaquen","name":"Usaquen","latitude":4.7059,"longitude":-74.0305,"radiusKm":8,"shippingInCents":6500}]
DELIVERY_ZONES_JSON=
